{
    "name": "azaharizaman/nexus-sourcing-operations",
    "description": "Nexus SourcingOperations Orchestrator - Cross-package workflow coordination for vendor sourcing and ecosystem management",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "azaharizaman/nexus-sourcing": "dev-main",
        "azaharizaman/nexus-sourcing-scoring": "dev-main",
        "azaharizaman/nexus-vendor": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\SourcingOperations\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\SourcingOperations\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
